[user]
	name = ekunazanu
	email = me@ekunazanu.foo
	signingkey = /home/ekunazanu/.ssh/hp.pub
[commit]
	gpgsign = true
[merge]
	tool = nvimdiff
	conflictstyle = diff3
[init]
	defaultBranch = main
[gpg]
	format = ssh
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
